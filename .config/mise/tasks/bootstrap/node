#!/usr/bin/env bash
#MISE description="Install default npm packages from the legacy ASDF package list"

set -o errexit
set -o nounset
set -o pipefail

source "$(dirname "$0")/_lib.sh"

load_packages "$(package_file node)"
if [[ ${#PACKAGES[@]} -eq 0 ]]; then
  printf 'No npm packages configured.\n'
  exit 0
fi

npm_prefix="$(data_home)/npm"
mkdir -p "$npm_prefix"
npm install --global --prefix "$npm_prefix" "${PACKAGES[@]}"
