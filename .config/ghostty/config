# Ghostty Configuration
# Modeline {
#	vi: foldmarker={,} foldmethod=marker foldlevel=0 filetype=config:
# }

# Documentation {
# Ref: https://ghostty.org/docs/config
# Ref: https://ghostty.org/docs/config/reference
# Reload conf: cmd+shift+,
# }

# General {
# This does not work reliably, as the Quick Terminal might consume this before the main window.
#initial-command = $SHELL -i -c "tmux || true; exec $SHELL"

# Start tmux if needed, otherwise $SHELL.
# Starting $SHELL after also serves as a drop-back from tmux, in case of issues running it.
# Start with $SHELL instead of the script directly so that it starts with env vars set.
#command = $SHELL -i -c "$HOME/bin/ghostty-tmux.sh || true; exec $SHELL"


# $SHELL -c: to start sub-commands with right env vars set + so we can add the drop-back shell.
# tmux new-session:
#    - tmux-continuum will restore session if the tmux server is started.
#    - Attach to "general" if exists, otherwise create and attach
# exec $SHELL: Drop-back from tmux, in case of issues running it.
# NOPE This approach breaks tmux-continuum restore because tmux is started inside a shell command chain (-c "tmux; exec $SHELL") instead of as the primary process, so the tmux server start is not detected cleanly and sessions are not restored.
#command = $SHELL -c "tmux new-session -As general || true; exec $SHELL"

# $SHELL -c: to start sub-commands with right env vars set for tmux.cong
command = $SHELL -c 'tmux new-session -As general'

# Disable audible bell
bell-features = no-audio

# Unlimited scrollback is not yet implemented.
scrollback-limit = 200000

# Automatically copy on selection
copy-on-select = clipboard

# Expose Ghostty to Shortcuts.app
macos-shortcuts = ask

auto-update = download
notify-on-command-finish = unfocused
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true

confirm-close-surface = false
quit-after-last-window-closed = true
# }

# UI {
# List themes with: $ ghostty +list-themes
theme = dark:iTerm2 Solarized Dark,light:iTerm2 Solarized Light

# Font style
#font-family = "Hack Nerd Font"
#font-size = 15

 # For powerlevel10 OMZ theme.
font-family = "MesloLGS NF"
font-size = 14

# Start window in maximized state
maximize = true

# Background
background-opacity = 0.90
background-blur = false

mouse-hide-while-typing
link-previews = true
# }

# Keybindings {
# Make left Opt key behave like Alt(Meta) so my tmux keybindings works.
macos-option-as-alt = left

# Global shortcut to toggle quick terminal dropdown.
keybind = global:cmd+`=toggle_quick_terminal
# }
